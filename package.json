{
  "name": "table-relay",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:verbose": "tauri dev -v",
    "tauri:build": "tauri build",
    "build:mac": "tauri build --bundles app && npm run sign:mac && npm run dmg:mac",
    "build:mac:universal": "tauri build --target universal-apple-darwin --bundles app && npm run sign:mac -- universal-apple-darwin && npm run dmg:mac -- universal-apple-darwin",
    "build:mac:intel": "tauri build --target x86_64-apple-darwin --bundles app && npm run sign:mac -- x86_64-apple-darwin && npm run dmg:mac -- x86_64-apple-darwin",
    "build:mac:app": "tauri build --bundles app && npm run sign:mac",
    "sign:mac": "bash scripts/sign-mac.sh",
    "dmg:mac": "bash scripts/make-dmg.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.0",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.7.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
