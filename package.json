{
  "name": "table-relay",
  "private": true,
  "version": "0.3.7",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:verbose": "tauri dev -v",
    "tauri:build": "tauri build",
    "build:mac": "tauri build --bundles app && npm run sign:mac && npm run dmg:mac",
    "build:mac:universal": "tauri build --target universal-apple-darwin --bundles app && npm run sign:mac -- universal-apple-darwin && npm run dmg:mac -- universal-apple-darwin",
    "build:mac:intel": "tauri build --target x86_64-apple-darwin --bundles app && npm run sign:mac -- x86_64-apple-darwin && npm run dmg:mac -- x86_64-apple-darwin",
    "build:mac:app": "tauri build --bundles app && npm run sign:mac",
    "sign:mac": "bash scripts/sign-mac.sh",
    "dmg:mac": "bash scripts/make-dmg.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.11",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.7",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.8.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
